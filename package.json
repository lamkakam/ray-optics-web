{
  "name": "ray-optics-web",
  "version": "0.34.2",
  "license": "BSD-3-Clause",
  "private": true,
  "scripts": {
    "generate:python-export-helpers": "node scripts/generate-python-export-helpers.mjs",
    "postinstall": "npm run generate:python-export-helpers",
    "predev": "npm run generate:python-export-helpers && bash scripts/build-python-wheel.sh",
    "dev": "next dev --webpack",
    "prebuild": "npm run generate:python-export-helpers && bash scripts/build-python-wheel.sh",
    "build": "next build --webpack",
    "generate:python-third-party-licenses": "src/python/.venv/bin/pip-licenses --format=markdown --with-urls --ignore-packages=rayoptics-web-utils --output-file=THIRD-PARTY-PYTHON-LICENSES.md",
    "generate:third-party-licenses": "license-checker-rseidelsohn --production --markdown --out THIRD-PARTY-LICENSES.md --clarificationsFile license-checker-clarifications.json && npm run generate:python-third-party-licenses",
    "postbuild": "node scripts/generate-next-static-sw.js && license-checker-rseidelsohn --production --markdown --out out/THIRD-PARTY-LICENSES.md --clarificationsFile license-checker-clarifications.json && src/python/.venv/bin/pip-licenses --format=markdown --with-urls --ignore-packages=rayoptics-web-utils --output-file=out/THIRD-PARTY-PYTHON-LICENSES.md",
    "serve": "npx serve out",
    "pretype-check": "npm run generate:python-export-helpers",
    "type-check": "tsc --noEmit",
    "prelint": "npm run generate:python-export-helpers",
    "lint": "eslint .",
    "pretest": "npm run generate:python-export-helpers",
    "test": "jest",
    "pretest:e2e": "npm run generate:python-export-helpers && bash scripts/build-python-wheel.sh",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@visx/axis": "4.0.0",
    "@visx/event": "4.0.0",
    "@visx/grid": "4.0.0",
    "@visx/group": "4.0.0",
    "@visx/legend": "4.0.0",
    "@visx/responsive": "4.0.0",
    "@visx/scale": "4.0.0",
    "@visx/shape": "4.0.0",
    "@visx/tooltip": "4.0.0",
    "@visx/zoom": "4.0.0",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "ajv": "^8.18.0",
    "better-react-mathjax": "^3.0.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "deck.gl": "^9.3.5",
    "echarts": "^6.0.0",
    "next": "^16.0.0",
    "pyodide": "314.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "license-checker-rseidelsohn": "^5.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "29.4.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
